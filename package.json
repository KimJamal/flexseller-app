{
  "name": "flexseller",
  "version": "2.0.0",
  "description": "FlexSeller - Professional Desktop Application for Component Search and Pricing",
  "main": "main.js",
  "homepage": "./",
  "author": "FlexSeller Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/KimJamal/flexseller-app.git"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.flexseller.app",
    "productName": "FlexSeller",
    "files": [
      "main.js",
      "Server.js",
      "FlexSeller.html",
      "assets/**/*",
      "node_modules/**/*",
      "config.json"
    ],
    "asar": false,
    "publish": [
      {
        "provider": "github",
        "owner": "KimJamal",
        "repo": "flexseller-app"
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/FlexSellerIcoP.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FlexSeller"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
